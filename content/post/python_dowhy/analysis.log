. predict ps, pr

. 
. * Step 2: Create 5 strata based on PS quintiles
. xtile ps_strata = ps, nquantiles(5)

. 
. * Step 3: Compute stratum-specific ATEs and weighted average
. scalar ps_strat_ate = 0

. scalar total_weight = 0

. 
. forvalues s = 1/5 {
  2.     quietly count if treat == 1 & ps_strata == `s'
  3.     scalar n_t = r(N)
  4.     quietly count if treat == 0 & ps_strata == `s'
  5.     scalar n_c = r(N)
  6. 
.     * Skip strata with no treated or no control observations
.     if n_t > 0 & n_c > 0 {
  7.         quietly summarize re78 if treat == 1 & ps_strata == `s'
  8.         scalar mean_t = r(mean)
  9.         quietly summarize re78 if treat == 0 & ps_strata == `s'
 10.         scalar mean_c = r(mean)
 11.         scalar ate_s = mean_t - mean_c
 12.         scalar w_s = n_t + n_c
 13.         scalar ps_strat_ate = ps_strat_ate + ate_s * w_s
 14.         scalar total_weight = total_weight + w_s
 15.         display "  Stratum `s': ATE = $" %10.2f ate_s " (n_t=" %3.0f n_t "
> , n_c=" %3.0f n_c ")"
 16.     }
 17.     else {
 18.         display "  Stratum `s': SKIPPED (empty treatment or control group)
> "
 19.     }
 20. }
