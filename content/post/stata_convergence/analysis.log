. 
. * ── Loop: for each start year, estimate OLS dropping each region ──
. local lastyear = 2019

. local j = 1

. 
. forval startyear = 1960(1)2010 {
  2.     local s = `lastyear' - `startyear'
  3. 
.     capture drop outcome initial
  4.     gen outcome = (1/`s') * ln(gdppc`lastyear' / gdppc`startyear')
  5.     gen initial = ln(gdppc`startyear')
  6. 
.     * Full sample OLS
.     qui reg outcome initial if !missing(outcome) & !missing(initial), robust
  7.     local b_full = _b[initial]
  8.     local lb_full = _b[initial] - invttail(`e(df_r)', 0.025) * _se[initial
> ]
  9.     local ub_full = _b[initial] + invttail(`e(df_r)', 0.025) * _se[initial
> ]
 10. 
.     * Drop each region
.     foreach cluster in "Africa" "Asia" "Latin America" {
 11.         qui reg outcome initial if clusters != "`cluster'" & !missing(outc
> ome) & !missing(initial), robust
 12.         local b_`=subinstr("`cluster'"," ","_",.)' = _b[initial]
 13.         local lb_`=subinstr("`cluster'"," ","_",.)' = _b[initial] - invtta
> il(`e(df_r)', 0.025) * _se[initial]
 14.         local ub_`=subinstr("`cluster'"," ","_",.)' = _b[initial] + invtta
> il(`e(df_r)', 0.025) * _se[initial]
 15.     }
 16. 
.     preserve
 17.         clear
 18.         set obs 1
 19.         tempfile reg`j'
 20.         gen year = `startyear'
 21.         gen period = `s'
 22.         gen beta_full = `b_full'
 23.         gen lb_full = `lb_full'
 24.         gen ub_full = `ub_full'
 25.         gen beta_noAfrica = `b_Africa'
 26.         gen lb_noAfrica = `lb_Africa'
 27.         gen ub_noAfrica = `ub_Africa'
 28.         gen beta_noAsia = `b_Asia'
 29.         gen lb_noAsia = `lb_Asia'
 30.         gen ub_noAsia = `ub_Asia'
 31.         gen beta_noLatAm = `b_Latin_America'
 32.         gen lb_noLatAm = `lb_Latin_America'
 33.         gen ub_noLatAm = `ub_Latin_America'
 34.         save `reg`j''
 35.     restore
 36. 
.     local ++j
 37. }
