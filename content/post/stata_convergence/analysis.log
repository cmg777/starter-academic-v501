. 
. * ── Loop over start years ──
. local j = 1

. local lastyear = 2019

. 
. forval startyear = 1960(1)2010 {
  2.     local s = `lastyear' - `startyear'
  3. 
.     capture drop outcome initial
  4.     gen outcome = (1/`s') * ln(gdppc`lastyear' / gdppc`startyear')
  5.     gen initial = ln(gdppc`startyear')
  6. 
.     * NLS estimation
.     capture qui nl (outcome = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'))/`s' * init
> ial) ///
>         if !missing(outcome) & !missing(initial), vce(robust)
  7. 
.     if _rc == 0 {
  8.         preserve
  9.             clear
 10.             set obs 1
 11.             tempfile file`j'
 12.             gen startyear = `startyear'
 13.             gen endyear = `lastyear'
 14.             gen beta = _b[/b1]
 15.             gen se = _se[/b1]
 16.             gen lower = _b[/b1] - invttail(`e(df_r)', 0.025) * _se[/b1]
 17.             gen upper = _b[/b1] + invttail(`e(df_r)', 0.025) * _se[/b1]
 18.             gen n = `e(N)'
 19.             * Speed and half-life
.             gen speed_pct = beta * 100
 20.             local cf = (1 - exp(-1*_b[/b1]*`s')) / `s'
 21.             gen halflife = .
 22.             if `cf' > 0 & `cf' < 1 {
 23.                 replace halflife = -ln(2) / ln(1 - `cf')
 24.             }
 25.             save `file`j''
 26.         restore
 27.         local ++j
 28.     }
 29.     else {
 30.         display as text "  Warning: NLS did not converge for start year `s
> tartyear'"
 31.         local ++j
 32.     }
 33. }
