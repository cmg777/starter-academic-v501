. * ── Loop over periods: OLS ──
. local nperiods : word count `periods'

. forval p = 1/`nperiods' {
  2.     local period : word `p' of `periods'
  3.     local sy : word `p' of `starts'
  4.     local ey : word `p' of `ends'
  5.     local s = `ey' - `sy'
  6. 
.     display as text ""
  7.     display as text "--- Period: `period' (s = `s' years) ---"
  8. 
.     preserve
  9.         use "convergence_working.dta", clear
 10.         keep ccode country year gdppc
 11.         reshape wide gdppc, i(ccode country) j(year)
 12. 
.         gen outcome = (1/`s') * ln(gdppc`ey' / gdppc`sy')
 13.         gen initial_inc = ln(gdppc`sy')
 14.         drop if missing(outcome) | missing(initial_inc)
 15. 
.         * ── OLS regression ──
.         reg outcome initial_inc, robust
 16.         local lambda = _b[initial_inc]
 17.         local se = _se[initial_inc]
 18.         local pval = 2 * ttail(e(df_r), abs(`lambda'/`se'))
 19.         local n_obs = e(N)
 20. 
.         * ── Convert λ to β ──
.         local lambda_s = `lambda' * `s'
 21.         if (1 + `lambda_s') > 0 {
 22.             local beta_speed = -ln(1 + `lambda_s') / `s'
 23.         }
 24.         else {
 25.             local beta_speed = .
 26.         }
 27.         local speed = `beta_speed' * 100
 28. 
.         * ── Half-life ──
.         if `beta_speed' > 0 & `beta_speed' < . {
 29.             local halflife = ln(2) / `beta_speed'
 30.         }
 31.         else {
 32.             local halflife = .
 33.         }
 34. 
.         display as result "  OLS λ = " %8.5f `lambda' " (SE = " %8.5f `se' ",
>  p = " %5.3f `pval' ")"
 35.         display as result "  Structural β = -ln(1 + " %7.5f `lambda' " × `
> s') / `s' = " %8.5f `beta_speed'
 36.         display as result "  Speed = " %5.2f `speed' "% per year"
 37.         if `halflife' < . {
 38.             display as result "  Half-life = ln(2) / " %7.5f `beta_speed' 
> " = " %6.1f `halflife' " years"
 39.         }
 40.         else {
 41.             display as result "  Half-life = not computable (no convergenc
> e)"
 42.         }
 43.         display as result "  N = " `n_obs' " countries"
 44.     restore
 45. 
.     * Store results
.     preserve
 46.         clear
 47.         set obs 1
 48.         gen str20 period = "`period'"
 49.         gen double lambda_ols = `lambda'
 50.         gen double se_lambda = `se'
 51.         gen double pvalue = `pval'
 52.         gen double beta_ols = `beta_speed'
 53.         gen double speed_ols = `speed'
 54.         gen double halflife_ols = `halflife'
 55.         gen int    n = `n_obs'
 56.         append using `ols_speed'
 57.         save `ols_speed', replace
 58.     restore
 59. }

