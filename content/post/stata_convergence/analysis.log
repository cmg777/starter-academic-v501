. 
. foreach decade in 1960 1970 1980 1990 2000 2010 {
  2.     local ey = `decade' + 10
  3.     if `ey' > 2019 local ey = 2019
  4.     local s = `ey' - `decade'
  5. 
.     * Beta (OLS): regress growth on initial income
.     capture drop g_temp i_temp logy_temp
  6.     gen g_temp = (1/`s') * ln(gdppc`ey' / gdppc`decade')
  7.     gen i_temp = ln(gdppc`decade')
  8.     qui reg g_temp i_temp if !missing(g_temp) & !missing(i_temp), robust
  9.     local b = _b[i_temp]
 10. 
.     * Sigma: variance of log income at the START of the decade
.     gen logy_temp = ln(gdppc`decade')
 11.     qui summarize logy_temp
 12.     local v = r(Var)
 13. 
.     * Determine interpretation
.     local interp = ""
 14.     if `b' >= 0 {
 15.         local interp = "β≥0: divergence"
 16.     }
 17.     else {
 18.         local interp = "β<0: convergence"
 19.     }
 20. 
.     display as text "  │ `decade'-`ey'  │ " %8.5f `b' " │ " %8.4f `v' "  │ `i
> nterp'     │"
 21.     drop g_temp i_temp logy_temp
 22. }
