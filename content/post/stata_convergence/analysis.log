. 
. * ── Loop over periods: NLS ──
. forval p = 1/`nperiods' {
  2.     local period : word `p' of `periods'
  3.     local sy : word `p' of `starts'
  4.     local ey : word `p' of `ends'
  5.     local s = `ey' - `sy'
  6. 
.     display as text ""
  7.     display as text "--- Period: `period' (s = `s' years) ---"
  8. 
.     preserve
  9.         use "convergence_working.dta", clear
 10.         keep ccode country year gdppc
 11.         reshape wide gdppc, i(ccode country) j(year)
 12. 
.         gen outcome = (1/`s') * ln(gdppc`ey' / gdppc`sy')
 13.         gen initial_inc = ln(gdppc`sy')
 14.         drop if missing(outcome) | missing(initial_inc)
 15. 
.         * ── NLS estimation ──
.         capture noisily nl (outcome = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'))/`s
> ' * initial_inc), ///
>             vce(robust)
 16. 
.         if _rc == 0 {
 17.             local beta_nls = _b[/b1]
 18.             local se_nls   = _se[/b1]
 19.             local n_obs    = e(N)
 20.             local pval_nls = 2 * ttail(e(df_r), abs(`beta_nls'/`se_nls'))
 21.             local speed = `beta_nls' * 100
 22. 
.             if `beta_nls' > 0 {
 23.                 local halflife = ln(2) / `beta_nls'
 24.             }
 25.             else {
 26.                 local halflife = .
 27.             }
 28. 
.             display as text ""
 29.             display as result "  NLS β = " %8.5f `beta_nls' " (SE = " %8.5
> f `se_nls' ", p = " %5.3f `pval_nls' ")"
 30.             display as result "  Speed = " %5.2f `speed' "% per year"
 31.             if `halflife' < . {
 32.                 display as result "  Half-life = " %6.1f `halflife' " year
> s"
 33.             }
 34.             else {
 35.                 display as result "  Half-life = not computable (no conver
> gence)"
 36.             }
 37.             display as result "  N = " `n_obs' " countries"
 38.         }
 39.         else {
 40.             display as error "  NLS did not converge for period `period'"
 41.             local beta_nls = .
 42.             local se_nls = .
 43.             local pval_nls = .
 44.             local speed = .
 45.             local halflife = .
 46.             local n_obs = .
 47.         }
 48.     restore
 49. 
.     if `beta_nls' < . {
 50.         preserve
 51.             clear
 52.             set obs 1
 53.             gen str20 period = "`period'"
 54.             gen double beta_nls = `beta_nls'
 55.             gen double se_nls = `se_nls'
 56.             gen double pvalue_nls = `pval_nls'
 57.             gen double speed_nls = `speed'
 58.             gen double halflife_nls = `halflife'
 59.             gen int    n = `n_obs'
 60.             append using `nls_speed'
 61.             save `nls_speed', replace
 62.         restore
 63.     }
 64. }

