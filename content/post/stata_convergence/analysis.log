. * ── Interpret the result ──
. local beta_ols = _b[initial]

. local se_ols   = _se[initial]

. local t_ols    = `beta_ols' / `se_ols'

. local p_ols    = 2 * ttail(e(df_r), abs(`t_ols'))

. 
