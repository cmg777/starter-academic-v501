. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. 
. display as text ""


. display as text "  KEY INSIGHT:"
  KEY INSIGHT:

. display as text "  β-convergence is NECESSARY but NOT SUFFICIENT for σ-conver
> gence."
