. 
. local j = 1

. forval yr = 1960(1)2019 {
  2.     gen logy = ln(gdppc`yr')
  3.     ci variances logy
  4.     preserve
  5.         clear
  6.         set obs 1
  7.         tempfile sigma`j'
  8.         gen year = `yr'
  9.         gen variance = r(Var)
 10.         gen var_lb = `r(lb)'
 11.         gen var_ub = `r(ub)'
 12.         gen n = `r(N)'
 13.         save `sigma`j''
 14.     restore
 15.     drop logy
 16.     local ++j
 17. }

