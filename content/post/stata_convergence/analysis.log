. * ── (B) Rolling NLS ──
. display as text ""


. display as text "--- (B) Rolling NLS (direct estimation) ---"
--- (B) Rolling NLS (direct estimation) ---

. local j = 1

. 
. forval startyear = 1960(1)2010 {
  2.     local s = `lastyear' - `startyear'
  3. 
.     capture drop outcome initial_inc
  4.     gen outcome = (1/`s') * ln(gdppc`lastyear' / gdppc`startyear')
  5.     gen initial_inc = ln(gdppc`startyear')
  6. 
.     capture qui nl (outcome = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'))/`s' * init
> ial_inc) ///
>         if !missing(outcome) & !missing(initial_inc), vce(robust)
  7. 
.     if _rc == 0 {
  8.         preserve
  9.             clear
 10.             set obs 1
 11.             tempfile nls_roll`j'
 12.             gen startyear = `startyear'
 13.             gen endyear = `lastyear'
 14.             gen beta = _b[/b1]
 15.             gen se = _se[/b1]
 16.             gen lower = _b[/b1] - invttail(`e(df_r)', 0.025) * _se[/b1]
 17.             gen upper = _b[/b1] + invttail(`e(df_r)', 0.025) * _se[/b1]
 18.             gen n = `e(N)'
 19.             gen speed_pct = beta * 100
 20.             gen halflife = .
 21.             if _b[/b1] > 0 {
 22.                 replace halflife = ln(2) / _b[/b1]
 23.             }
 24.             save `nls_roll`j''
 25.         restore
 26.         local ++j
 27.     }
 28.     else {
 29.         display as text "  Warning: NLS did not converge for start year `s
> tartyear'"
 30.         local ++j
 31.     }
 32. }
