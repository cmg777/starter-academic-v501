>    ylabel(, angle(horizontal))
>    ytitle("Variance of ln(GDP per capita)", size(medsmall))
>    xtitle("Year")
>    title("Sigma Convergence: Income Dispersion Over Time", color("20 20 19") 
> size(medium))
