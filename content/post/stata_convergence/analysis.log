file /var/folders/tq/t98kb27n6djgrh085g476yhc0000gn/T//St41240.000002 saved
    as .dta format

. restore

. 
. * ── Loop over periods ──
. local nperiods : word count `periods'

. forval p = 1/`nperiods' {
  2.     local period : word `p' of `periods'
  3.     local sy : word `p' of `starts'
  4.     local ey : word `p' of `ends'
  5.     local s = `ey' - `sy'
  6. 
.     display as text ""
  7.     display as text "--- Period: `period' (s = `s' years) ---"
  8. 
.     * Reload and reshape for each period to use maximum available sample
.     preserve
  9.         use "convergence_working.dta", clear
 10.         keep ccode country year gdppc
 11.         reshape wide gdppc, i(ccode country) j(year)
 12. 
.         * Calculate variables for this period
.         gen outcome_temp = (1/`s') * ln(gdppc`ey' / gdppc`sy')
 13.         gen initial_temp = ln(gdppc`sy')
 14.         drop if missing(outcome_temp) | missing(initial_temp)
 15. 
.         * ── NLS estimation (Barro-Sala-i-Martin specification) ──
.         capture noisily nl (outcome_temp = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'
> ))/`s' * initial_temp), ///
>             vce(robust)
 16. 
.         if _rc == 0 {
 17.             local beta_nls = _b[/b1]
 18.             local se_nls   = _se[/b1]
 19.             local n_obs    = e(N)
 20. 
.             * Speed of convergence (in percent per year)
.             local speed = `beta_nls' * 100
 21. 
.             * Half-life: τ = -ln(2) / ln(1 - (1 - exp(-β×s))/s)
.             local convergence_factor = (1 - exp(-1*`beta_nls'*`s')) / `s'
 22.             if `convergence_factor' > 0 & `convergence_factor' < 1 {
 23.                 local halflife = -ln(2) / ln(1 - `convergence_factor')
 24.             }
 25.             else {
 26.                 local halflife = .
 27.             }
 28. 
.             * Also compute simple OLS for comparison
.             qui reg outcome_temp initial_temp, robust
 29.             local beta_ols_val = _b[initial_temp]
 30. 
.             display as text ""
 31.             display as result "  NLS β = " %8.5f `beta_nls' " (SE = " %8.5
> f `se_nls' ")"
 32.             display as result "  Speed of convergence = " %5.2f `speed' "%
>  per year"
 33.             if `halflife' < . {
 34.                 display as result "  Half-life = " %6.1f `halflife' " year
> s"
 35.             }
 36.             else {
 37.                 display as result "  Half-life = not computable (no conver
> gence)"
 38.             }
 39.             display as result "  OLS β (linear) = " %8.5f `beta_ols_val'
 40.             display as result "  N = " `n_obs' " countries"
 41.         }
 42.         else {
 43.             display as error "  NLS did not converge for period `period'"
 44.             local beta_nls = .
 45.             local se_nls = .
 46.             local speed = .
 47.             local halflife = .
 48.             local beta_ols_val = .
 49.             local n_obs = .
 50.         }
 51.     restore
 52. 
.     * Store results (outside preserve/restore so tempfile is accessible)
.     if `beta_nls' < . {
 53.         preserve
 54.             clear
 55.             set obs 1
 56.             gen str20 period = "`period'"
 57.             gen str5  method = "NLS"
 58.             gen double beta_nls = `beta_nls'
 59.             gen double se_nls = `se_nls'
 60.             gen double speed_pct = `speed'
 61.             gen double halflife = `halflife'
 62.             gen double beta_ols = `beta_ols_val'
 63.             gen int    n = `n_obs'
 64.             append using `speed_results'
 65.             save `speed_results', replace
 66.         restore
 67.     }
 68. }

