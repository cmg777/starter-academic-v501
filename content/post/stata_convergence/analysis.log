. display as text ""


. display as text "  EMPIRICAL DEMONSTRATION:"
  EMPIRICAL DEMONSTRATION:

. display as text "  Decade-by-decade OLS λ and variance of log income:"
  Decade-by-decade OLS λ and variance of log income:

. display as text ""


. display as text "  ┌─────────────┬───────────┬───────────┬───────────────────
> ─────────┐"
  ┌─────────────┬───────────┬───────────┬────────────────────────────┐

. display as text "  │ Decade      │ OLS λ     │ σ² start  │ Interpretation    
>          │"
  │ Decade      │ OLS λ     │ σ² start  │ Interpretation             │

. display as text "  ├─────────────┼───────────┼───────────┼───────────────────
> ─────────┤"
  ├─────────────┼───────────┼───────────┼────────────────────────────┤

. 
. foreach decade in 1960 1970 1980 1990 2000 2010 {
  2.     local ey = `decade' + 10
  3.     if `ey' > 2019 local ey = 2019
  4.     local s = `ey' - `decade'
  5. 
.     * Beta (OLS): regress growth on initial income
.     capture drop g_temp i_temp logy_temp
  6.     gen g_temp = (1/`s') * ln(gdppc`ey' / gdppc`decade')
  7.     gen i_temp = ln(gdppc`decade')
  8.     qui reg g_temp i_temp if !missing(g_temp) & !missing(i_temp), robust
  9.     local b = _b[i_temp]
 10. 
.     * Sigma: variance of log income at the START of the decade
.     gen logy_temp = ln(gdppc`decade')
 11.     qui summarize logy_temp
 12.     local v = r(Var)
 13. 
.     * Determine interpretation
.     local interp = ""
 14.     if `b' >= 0 {
 15.         local interp = "λ≥0: divergence"
 16.     }
 17.     else {
 18.         local interp = "λ<0: convergence"
 19.     }
 20. 
.     display as text "  │ `decade'-`ey'  │ " %8.5f `b' " │ " %8.4f `v' "  │ `i
> nterp'     │"
 21.     drop g_temp i_temp logy_temp
 22. }
  │ 1960-1970  │  0.00594 │   0.9244  │ λ≥0: divergence     │
  │ 1970-1980  │  0.00555 │   1.0818  │ λ≥0: divergence     │
  │ 1980-1990  │  0.00686 │   1.2893  │ λ≥0: divergence     │
  │ 1990-2000  │  0.00882 │   1.5384  │ λ≥0: divergence     │
  │ 2000-2010  │ -0.00379 │   1.8937  │ λ<0: convergence     │
  │ 2010-2019  │ -0.00305 │   1.8262  │ λ<0: convergence     │

