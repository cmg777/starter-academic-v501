. *════════════════════════════════════════════════════════════════════════════
> ═══
. * SECTION 7: ROLLING BETA CONVERGENCE — OLS AND NLS
. *
. *   Instead of just two snapshots, let's see the FULL MOVIE:
. *     How has the convergence coefficient evolved year by year?
. *
. *   Method: Fix the end year at 2019. For each start year from 1960 to 2010,
. *   estimate the convergence β using:
. *     (A) OLS λ → β conversion
. *     (B) NLS direct estimation
. *
. *   This gives us TWO rolling-window time series of β.
. *
. *   Convention:
. *     β > 0 → convergence (poorer countries catching up)
. *     β < 0 → divergence (gap widening)
. *════════════════════════════════════════════════════════════════════════════
> ═══
. 
. display as text ""


. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. display as text "  SECTION 7: ROLLING BETA CONVERGENCE — OLS AND NLS"
  SECTION 7: ROLLING BETA CONVERGENCE — OLS AND NLS

. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. 
. * ── Load and reshape data ──
. use "convergence_working.dta", clear

. keep ccode country year gdppc

. reshape wide gdppc, i(ccode country) j(year)
(j = 1960 1961 1962 1963 1964 1965 1966 1967 1968 1969 1970 1971 1972 1973 1974
>  1975 1976 1977 1978 1979 1980 1981 1982 1983 1984 1985 1986 1987 1988 1989 1
> 990 1991 1992 1993 1994 1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 200
> 5 2006 2007 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019)

Data                               Long   ->   Wide
-----------------------------------------------------------------------------
Number of observations            5,040   ->   84          
Number of variables                   4   ->   62          
j variable (60 values)             year   ->   (dropped)
xij variables:
                                  gdppc   ->   gdppc1960 gdppc1961 ... gdppc201
> 9
-----------------------------------------------------------------------------

. 
. * ── (A) Rolling OLS ──
. display as text ""


. display as text "--- (A) Rolling OLS (λ → β conversion) ---"
--- (A) Rolling OLS (λ → β conversion) ---

. local j = 1

. local lastyear = 2019

. 
. forval startyear = 1960(1)2010 {
  2.     local s = `lastyear' - `startyear'
  3. 
.     capture drop outcome initial_inc
  4.     gen outcome = (1/`s') * ln(gdppc`lastyear' / gdppc`startyear')
  5.     gen initial_inc = ln(gdppc`startyear')
  6. 
.     qui reg outcome initial_inc if !missing(outcome) & !missing(initial_inc),
>  robust
  7.     local lambda = _b[initial_inc]
  8.     local se_lambda = _se[initial_inc]
  9.     local n_obs = e(N)
 10. 
.     * Convert λ to β
.     local lambda_s = `lambda' * `s'
 11.     if (1 + `lambda_s') > 0 {
 12.         local beta_val = -ln(1 + `lambda_s') / `s'
 13.     }
 14.     else {
 15.         local beta_val = .
 16.     }
 17. 
.     * Convert λ CI to β CI (bounds flip because the function is monotone decr
> easing)
.     local lambda_lb = `lambda' - invttail(e(df_r), 0.025) * `se_lambda'
 18.     local lambda_ub = `lambda' + invttail(e(df_r), 0.025) * `se_lambda'
 19.     if (1 + `lambda_lb'*`s') > 0 {
 20.         local beta_ub = -ln(1 + `lambda_lb'*`s') / `s'
 21.     }
 22.     else {
 23.         local beta_ub = .
 24.     }
 25.     if (1 + `lambda_ub'*`s') > 0 {
 26.         local beta_lb = -ln(1 + `lambda_ub'*`s') / `s'
 27.     }
 28.     else {
 29.         local beta_lb = .
 30.     }
 31. 
.     preserve
 32.         clear
 33.         set obs 1
 34.         tempfile ols_roll`j'
 35.         gen startyear = `startyear'
 36.         gen endyear = `lastyear'
 37.         gen beta = `beta_val'
 38.         gen lower = `beta_lb'
 39.         gen upper = `beta_ub'
 40.         gen speed_pct = `beta_val' * 100
 41.         gen halflife = .
 42.         if `beta_val' > 0 & `beta_val' < . {
 43.             replace halflife = ln(2) / `beta_val'
 44.         }
 45.         gen n = `n_obs'
 46.         save `ols_roll`j''
 47.     restore
 48.     local ++j
 49. }
