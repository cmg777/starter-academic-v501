.     #delimit ;
delimiter now ;
.     tw (rcap lower upper startyear, lcolor("217 119 87"%30))
>        (scatter beta startyear, mcolor("217 119 87"%80) msymbol(O) msize(smal
> l)),
>        yline(0, lcolor("20 20 19") lpattern(shortdash) lwidth(medium))
>        xlabel(1960(5)2010, angle(45))
