. *════════════════════════════════════════════════════════════════════════════
> ═══
. * SECTION 11: THE CONVERGENCE HEATMAP — OLS AND NLS
. *
. *   The most comprehensive view of convergence:
. *     For EVERY combination of start year and end year,
. *     estimate the β coefficient and color-code it.
. *
. *   We produce TWO heatmaps:
. *     (A) OLS-based: estimate λ, convert to β = -ln(1+λs)/s
. *     (B) NLS-based: estimate β directly (reproduces Patel et al. 2021 Fig 2)
. *
. *   Blue = convergence (β > 0), Red = divergence (β < 0)
. *════════════════════════════════════════════════════════════════════════════
> ═══
. 
. display as text ""


. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. display as text "  SECTION 11: THE CONVERGENCE HEATMAP — OLS AND NLS"
  SECTION 11: THE CONVERGENCE HEATMAP — OLS AND NLS

. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. 
. * ── Load and reshape ──
. use "convergence_working.dta", clear

. keep ccode country year gdppc

. reshape wide gdppc, i(ccode country) j(year)
(j = 1960 1961 1962 1963 1964 1965 1966 1967 1968 1969 1970 1971 1972 1973 1974
>  1975 1976 1977 1978 1979 1980 1981 1982 1983 1984 1985 1986 1987 1988 1989 1
> 990 1991 1992 1993 1994 1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 200
> 5 2006 2007 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019)

Data                               Long   ->   Wide
-----------------------------------------------------------------------------
Number of observations            5,040   ->   84          
Number of variables                   4   ->   62          
j variable (60 values)             year   ->   (dropped)
xij variables:
                                  gdppc   ->   gdppc1960 gdppc1961 ... gdppc201
> 9
-----------------------------------------------------------------------------

. 
. * ── Loop over ALL start/end year combinations ──
. local j = 1

. local firstyear = 1960

. local lastyear = 2019

. local endyear_loop = `lastyear' - 1

. 
. forval startyear = `firstyear'(1)`endyear_loop' {
  2.     local startplus1 = `startyear' + 1
  3.     forval outcomeyear = `startplus1'(1)`lastyear' {
  4.         local s = `outcomeyear' - `startyear'
  5. 
.         capture drop outcome initial_inc
  6.         gen outcome = (1/`s') * ln(gdppc`outcomeyear' / gdppc`startyear')
  7.         gen initial_inc = ln(gdppc`startyear')
  8. 
.         * ── OLS ──
.         local beta_ols_hm = .
  9.         local n_hm = .
 10.         capture qui reg outcome initial_inc if !missing(outcome) & !missin
> g(initial_inc), robust
 11.         if _rc == 0 {
 12.             local lambda_hm = _b[initial_inc]
 13.             local n_hm = e(N)
 14.             local lambda_s_hm = `lambda_hm' * `s'
 15.             if (1 + `lambda_s_hm') > 0 {
 16.                 local beta_ols_hm = -ln(1 + `lambda_s_hm') / `s'
 17.             }
 18.         }
 19. 
.         * ── NLS ──
.         local beta_nls_hm = .
 20.         capture qui nl (outcome = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'))/`s'
>  * initial_inc) ///
>             if !missing(outcome) & !missing(initial_inc), vce(robust)
 21.         if _rc == 0 {
 22.             local beta_nls_hm = _b[/b1]
 23.         }
 24. 
.         preserve
 25.             clear
 26.             set obs 1
 27.             tempfile hm`j'
 28.             gen startyear = `startyear'
 29.             gen endyear = `outcomeyear'
 30.             gen beta_ols = `beta_ols_hm'
 31.             gen beta_nls = `beta_nls_hm'
 32.             gen n = `n_hm'
 33.             save `hm`j''
 34.         restore
 35. 
.         local ++j
 36.     }
 37.     * Progress indicator every 5 years
.     if mod(`startyear' - `firstyear', 5) == 0 {
 38.         display as text "  Processing start year: `startyear'..."
 39.     }
 40. }
