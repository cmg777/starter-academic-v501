. *════════════════════════════════════════════════════════════════════════════
> ═══
. * SECTION 8: THE CONVERGENCE HEATMAP — ALL WINDOWS
. *
. *   The most comprehensive view of convergence:
. *     For EVERY combination of start year and end year,
. *     estimate the β coefficient and color-code it.
. *
. *   This reproduces Figure 2 from Patel et al. (2021).
. *
. *   Blue = convergence (positive β), Red = divergence (negative β)
. *
. *   Along lines parallel to the diagonal, you see how convergence
. *   changes over time for a FIXED growth interval (rolling window).
. *   This shows that convergence is not an artifact of choosing 2019
. *   as the end year — it appears across many time windows.
. *════════════════════════════════════════════════════════════════════════════
> ═══
. 
. display as text ""


. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. display as text "  SECTION 8: THE CONVERGENCE HEATMAP"
  SECTION 8: THE CONVERGENCE HEATMAP

. display as text "────────────────────────────────────────────────────────────
> ────"
────────────────────────────────────────────────────────────────

. 
. * ── Load and reshape ──
. use "convergence_working.dta", clear

. keep ccode country year gdppc

. reshape wide gdppc, i(ccode country) j(year)
(j = 1960 1961 1962 1963 1964 1965 1966 1967 1968 1969 1970 1971 1972 1973 1974
>  1975 1976 1977 1978 1979 1980 1981 1982 1983 1984 1985 1986 1987 1988 1989 1
> 990 1991 1992 1993 1994 1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 200
> 5 2006 2007 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019)

Data                               Long   ->   Wide
-----------------------------------------------------------------------------
Number of observations            6,612   ->   124         
Number of variables                   4   ->   62          
j variable (60 values)             year   ->   (dropped)
xij variables:
                                  gdppc   ->   gdppc1960 gdppc1961 ... gdppc201
> 9
-----------------------------------------------------------------------------

. 
. * ── Loop over ALL start/end year combinations ──
. local j = 1

. local firstyear = 1960

. local lastyear = 2019

. local endyear_loop = `lastyear' - 1

. 
. forval startyear = `firstyear'(1)`endyear_loop' {
  2.     local startplus1 = `startyear' + 1
  3.     forval outcomeyear = `startplus1'(1)`lastyear' {
  4.         local s = `outcomeyear' - `startyear'
  5. 
.         capture drop outcome initial
  6.         gen outcome = (1/`s') * ln(gdppc`outcomeyear' / gdppc`startyear')
  7.         gen initial = ln(gdppc`startyear')
  8. 
.         capture qui nl (outcome = {b0=1} - (1 - exp(-1*{b1=0.00}*`s'))/`s' * 
> initial) ///
>             if !missing(outcome) & !missing(initial), vce(robust)
  9. 
.         if _rc == 0 {
 10.             preserve
 11.                 clear
 12.                 set obs 1
 13.                 tempfile hm`j'
 14.                 gen startyear = `startyear'
 15.                 gen endyear = `outcomeyear'
 16.                 gen beta = _b[/b1]
 17.                 gen se = _se[/b1]
 18.                 gen n = `e(N)'
 19.                 save `hm`j''
 20.             restore
 21.         }
 22.         local ++j
 23.     }
 24.     * Progress indicator every 5 years
.     if mod(`startyear' - `firstyear', 5) == 0 {
 25.         display as text "  Processing start year: `startyear'..."
 26.     }
 27. }
