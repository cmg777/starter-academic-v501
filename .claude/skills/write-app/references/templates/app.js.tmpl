// app.js — generated by /project:write-app from app.js.tmpl.
// Wires DOM controls to dgp/lasso/charts modules. Runs after
// window.DGP, window.LASSO, and window.CHARTS are defined.

(function () {
  "use strict";

  // ---- Tab switching ---------------------------------------------------------
  function activateTab(paneId) {
    document.querySelectorAll(".tab-strip button").forEach(btn => {
      const isActive = btn.dataset.pane === paneId;
      btn.classList.toggle("active", isActive);
      btn.setAttribute("aria-selected", isActive ? "true" : "false");
    });
    document.querySelectorAll(".tab-pane").forEach(pane => {
      pane.classList.toggle("active", pane.id === paneId);
    });
    window.scrollTo({ top: 0, behavior: "smooth" });
  }
  document.querySelectorAll(".tab-strip button").forEach(btn => {
    btn.addEventListener("click", () => activateTab(btn.dataset.pane));
  });
  document.querySelectorAll(".cta-card[data-goto]").forEach(card => {
    card.addEventListener("click", () => activateTab(card.dataset.goto));
  });

  // ---- Generic debounce ------------------------------------------------------
  function debounce(fn, ms) {
    let h = null;
    return function () { clearTimeout(h); h = setTimeout(fn, ms); };
  }

  // ---- Widget initialisations ------------------------------------------------
  // The skill substitutes {{WIDGET_INIT}} with one call per selected widget,
  // in tab order. Each widget fragment (see references/templates/widgets/) is
  // a self-contained IIFE that mounts itself to the DOM IDs defined in its
  // matching HTML pane.
{{WIDGET_INIT}}

  // ---- Forest-plot data loader (only emitted when a widget needs results.json)
{{DATA_LOADER}}

  // ---- Global error handler --------------------------------------------------
  window.addEventListener("error", function (e) {
    console.error("[write-app] uncaught error:", e.error);
  });
})();
