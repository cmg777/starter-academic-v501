---
title: "{{TITLE}}"
subtitle: "{{SUBTITLE}}"
deck-author: "{{AUTHOR}}"           # title-slide author name (hyperlinked below)
deck-author-url: "{{AUTHOR_URL}}"   # the author's homepage, e.g. https://carlos-mendez.org
institute: "{{INSTITUTE}}"          # the university line, e.g. Nagoya University (GSID)
date: today                         # auto-stamps the render/update date ("created or updated")
date-format: long                   # renders e.g. "June 11, 2026"
key-results:                  # the title-slide number strip — 3 headline numbers (from results_report.md)
{{KEY_RESULTS}}               #   - num: "−0.096"
                              #     cap: "rigorous Double-LASSO"
format:
  revealjs:
    output-file: index.html
    # NOT embed-resources: RevealChalkboard (a core feature) is incompatible with
    # self-contained output, so the deck ships index.html + slides_files/ (Hugo serves
    # this fine — see the tutorial.html precedent). Figures are referenced ../<slug>_*.png.
    theme: [default, site-brand.scss]
    template-partials:
      - title-slide.html
    center: true              # vertical-centres content → centred dividers + strategic white space
    slide-number: c/t
    menu: true                # revealjs-menu plugin (press M)
    chalkboard: true          # draw on slides (press B)
    preview-links: auto
    overview: true            # press O
    progress: true
    history: true
    transition: fade
    width: 1280
    height: 720
    fig-align: center         # + auto-stretch (default on) bounds images to the slide → no overflow
    auto-stretch: true
    highlight-style: github
    # Math: MathJax (Quarto revealjs DEFAULT) — renders $…$ / $$…$$ across the whole slide
    # DOM (body, captions, headings, table cells). Loads from a CDN; reveal.js is local.
    # Do NOT set `html-math-method: katex` — it is broken in revealjs (no auto-render call,
    # so math shows as raw LaTeX). See references/render-and-fix.md.
    link-external-icon: false
---

