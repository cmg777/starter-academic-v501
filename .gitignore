# IDEs
.idea/

# Hugo
/resources/
public/
jsconfig.json
node_modules/
.Rproj.user
.venv/

# macOS
.DS_Store

# AJR (2001) reference materials — third-party; not committed
content/post/stata_iv/references/

# Fitzgerald et al. (2026) replication archive for r_double_lasso (~510 MB);
# Matlab .mat files + R source from the JAE Journal Data Archive. The CSVs
# extracted by prepare_data.R live in data/ and ARE committed.
content/post/r_double_lasso/references/

# Clarke et al. (2024) SDID Stata Journal paper for stata_sdid — third-party
# source (paper markdown + online_supplementary_material.pdf + sdidExamples.pdf
# + replication_materials.do); Hugo would publish the PDFs. The post cites the
# paper in References; the source archive is not committed.
content/post/stata_sdid/references/

# Ben-Michael, Feller & Rothstein (2021) ASCM paper + the full augsynth package
# source (R/, data/, man/, vignettes/figure/ — several MB incl. a 1.5 MB raw .dta)
# for r_augsynth — third-party reference material. The post is self-contained:
# kansas.csv is regenerated from the package and committed, and analysis.R loads
# it from a GitHub raw URL. The paper is cited in References; source not committed.
content/post/r_augsynth/references/

# Clarke, Pailanir, Athey & Imbens (2024) SDID Stata Journal paper (full-text .md
# + 265 KB online_supplementary_material.pdf) and replication_materials.do for
# stata_sdid_staggered -- third-party reference material; Hugo would publish them.
# The post is self-contained: quota_example.dta is committed and analysis.do
# re-fetches it; the paper is cited in References. Source archive not committed.
content/post/stata_sdid_staggered/reference/

# Stata batch-mode auto-log artifact (the real log is analysis.log)
content/post/stata_iv/stata.log

# Python venv for python_iv post (build artifact, not source)
content/post/python_iv/.venv/

# Third-party MGWR fork cloned by the python_mgwrfer script (~18 MB; not source)
content/post/python_mgwrfer/mgwpr_repo/

# Sakaguchi & Tagawa replication package for r_sc_bayes_spatial (~148 MB,
# includes a 129 MB raw CSV that exceeds GitHub's per-file limit). The 11
# files analysis.R actually needs are copied into helpers/.
content/post/r_sc_bayes_spatial/replication-package/

# Baker et al. (2025) DiD practitioner's guide source manuscript for r_did2
# (~220 KB LaTeX; third-party reference material, not source for this post).
content/post/r_did2/reference/manuscript.tex

# Quarto render artefacts in any post directory (tutorial.qmd is the source;
# readers render their own HTML locally). Python bundles place tutorial.qmd
# under references/, so render artefacts land there too.
content/post/*/tutorial.html
content/post/*/tutorial_files/
content/post/*/tutorial-render.log
content/post/*/references/tutorial.html
content/post/*/references/tutorial_files/
content/post/*/references/tutorial-render.log
content/post/*/references/.venv/
content/post/*/references/.quarto/

# Quarto SLIDE-DECK output is the OPPOSITE of the tutorial artefacts above: the
# rendered deck (slides/index.html + slides/slides_files/) IS served by Netlify
# (which runs Hugo, not Quarto), so it MUST be committed. Only ignore Quarto's
# local render cache here — never slides_files/. (Generated by the write-slides skill.)
content/post/*/slides/.quarto/

# pydynpd package source used only as reference material for the python_dynamic_panel
# tutorial — never publish or commit it (Hugo would copy ~7MB into public/).
content/post/python_dynamic_panel/referenceMaterials/

# Lessmann & Seidel (2017) replication archive — reference material only for the
# python_kuznets_dmsp tutorial — never publish or commit it (Hugo would copy ~166MB
# into public/). Kept on local disk for reference; Netlify builds from git so it
# never reaches production.
content/post/python_kuznets_dmsp/Lessmann-2017-Regional-inequality-convergence-and-its-determinants/

# LaTeX CV build artifacts (content/cv/). The CV SOURCE — main.tex, the moderncv
# .cls/.sty files, avatar.png, certificates/ — IS committed; only the transient
# compile outputs are ignored. The published PDF is static/media/CV.pdf (compiled
# and copied there by the update-cv skill), NOT content/cv/main.pdf.
content/cv/*.aux
content/cv/*.log
content/cv/*.out
content/cv/*.fls
content/cv/*.fdb_latexmk
content/cv/*.synctex.gz
content/cv/*.toc
content/cv/*.bbl
content/cv/*.blg
content/cv/main.pdf
