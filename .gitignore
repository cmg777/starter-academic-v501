# IDEs
.idea/

# Hugo
/resources/
public/
jsconfig.json
node_modules/
.Rproj.user
.venv/

# macOS
.DS_Store

# AJR (2001) reference materials — third-party; not committed
content/post/stata_iv/references/

# Fitzgerald et al. (2026) replication archive for r_double_lasso (~510 MB);
# Matlab .mat files + R source from the JAE Journal Data Archive. The CSVs
# extracted by prepare_data.R live in data/ and ARE committed.
content/post/r_double_lasso/references/

# Clarke et al. (2024) SDID Stata Journal paper for stata_sdid — third-party
# source (paper markdown + online_supplementary_material.pdf + sdidExamples.pdf
# + replication_materials.do); Hugo would publish the PDFs. The post cites the
# paper in References; the source archive is not committed.
content/post/stata_sdid/references/

# Stata batch-mode auto-log artifact (the real log is analysis.log)
content/post/stata_iv/stata.log

# Python venv for python_iv post (build artifact, not source)
content/post/python_iv/.venv/

# Third-party MGWR fork cloned by the python_mgwrfer script (~18 MB; not source)
content/post/python_mgwrfer/mgwpr_repo/

# Sakaguchi & Tagawa replication package for r_sc_bayes_spatial (~148 MB,
# includes a 129 MB raw CSV that exceeds GitHub's per-file limit). The 11
# files analysis.R actually needs are copied into helpers/.
content/post/r_sc_bayes_spatial/replication-package/

# Baker et al. (2025) DiD practitioner's guide source manuscript for r_did2
# (~220 KB LaTeX; third-party reference material, not source for this post).
content/post/r_did2/reference/manuscript.tex

# Quarto render artefacts in any post directory (tutorial.qmd is the source;
# readers render their own HTML locally). Python bundles place tutorial.qmd
# under references/, so render artefacts land there too.
content/post/*/tutorial.html
content/post/*/tutorial_files/
content/post/*/tutorial-render.log
content/post/*/references/tutorial.html
content/post/*/references/tutorial_files/
content/post/*/references/tutorial-render.log
content/post/*/references/.venv/
content/post/*/references/.quarto/
